# ============================================================
# JNC Notificaciones Pipeline - .gitignore
# ============================================================
# Este repositorio NO debe contener:
# - datos reales
# - archivos Excel/PDF operativos
# - credenciales
# - connection strings
# - tokens
# - información sensible o médica
# ============================================================


# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.python-version

build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
pip-wheel-metadata/
*.egg-info/
.installed.cfg
*.egg
MANIFEST


# ============================================================
# Virtual environments
# ============================================================
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/


# ============================================================
# Azure Functions
# ============================================================
local.settings.json
.funcignore
.azurefunctions/
.python_packages/
bin/
obj/


# ============================================================
# Environment variables / secrets
# ============================================================
.env
.env.*
*.env
secrets.json
appsettings.json
appsettings.*.json

*.pem
*.key
*.pfx
*.p12
*.cer
*.crt
*.csr

*.publishsettings


# Keep safe examples
!local.settings.example.json
!.env.example
!appsettings.example.json
payload.json
payload_correo_certificado.json

# ============================================================
# Data files - do not upload real operational data
# ============================================================
data/
input/
inputs/
output/
outputs/
raw/
processed/
procesados/
staging/
tmp/
temp/
exports/
samples/private/
fixtures/private/

*.xlsx
*.xlsm
*.xls
*.csv
*.tsv
*.parquet
*.jsonl
*.pdf
*.zip
*.7z
*.rar


# ============================================================
# Allow safe sample templates if needed
# ============================================================
!samples/
!samples/README.md
!samples/**/*.md
!samples/**/*.txt
!samples/**/*.csv.example
!samples/**/*.xlsx.example
!samples/**/*.json.example


# ============================================================
# Database files / backups
# ============================================================
*.db
*.sqlite
*.sqlite3
*.bak
*.bacpac
*.dacpac


# ============================================================
# Logs and runtime files
# ============================================================
*.log
logs/
log/
debug.log
trace.log
*.pid


# ============================================================
# Test / coverage
# ============================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
.junit/
test-results/


# ============================================================
# Jupyter notebooks
# ============================================================
.ipynb_checkpoints/
*.ipynb

# If you later decide to version safe notebooks, remove *.ipynb
# and ensure notebooks contain no outputs or sensitive data.


# ============================================================
# VS Code / IDE
# ============================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json

.idea/
*.code-workspace


# ============================================================
# OS files
# ============================================================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
desktop.ini
ehthumbs.db


# ============================================================
# Office temporary files
# ============================================================
~$*
*.tmp


# ============================================================
# Power BI files
# ============================================================
*.pbix
*.pbit


# ============================================================
# Azure / deployment artifacts
# ============================================================
.azure/
publish/
deployment/
deploy/
site/
wwwroot.zip


# ============================================================
# Node artifacts, in case tooling creates them
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ============================================================
# Local documentation drafts with sensitive notes
# ============================================================
notes_private/
private_notes/
*.private.md
